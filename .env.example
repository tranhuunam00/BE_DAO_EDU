# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
PORT=5005
JWT_SECRET=your_jwt_secret_key_here
APP_VERSION=v1.0.0

# =============================================================================
# DATABASE CONFIGURATION (POSTGRESQL)
# =============================================================================
# Sử dụng 'localhost' nếu Backend và Postgres cùng chạy chung 1 server/máy local.
# Nhập IP của server nếu Database chạy trên server riêng biệt.
DATABASE_HOST=localhost
DATABASE_PORT=5435
DATABASE_USER=dao_edu_db_admin
DATABASE_PASSWORD=your_postgres_password_here
DATABASE_NAME=dao_edu_db

# =============================================================================
# STORAGE CONFIGURATION (MINIO / S3)
# =============================================================================
# Sử dụng 'localhost' nếu Backend và MinIO cùng chạy chung 1 server/máy local.
# Nhập IP của server nếu MinIO chạy trên server riêng biệt.
MINIO_ENDPOINT=localhost
MINIO_PORT=9005
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=dao_minio_root
MINIO_SECRET_KEY=your_minio_password_here
MINIO_BUCKET_NAME=edu

# =============================================================================
# VIETQR - MANUAL BANK TRANSFER REQUESTS
# =============================================================================
# Bank code/BIN supported by VietQR, for example: MB, VCB, BIDV
VIETQR_BANK_CODE=
VIETQR_ACCOUNT_NUMBER=
VIETQR_ACCOUNT_NAME=

# Credentials provided by DAO EDU to VietQR for callback authentication.
VIETQR_CALLBACK_USERNAME=
VIETQR_CALLBACK_PASSWORD=
VIETQR_CALLBACK_JWT_SECRET=

# Local/UAT only. Never enable this in production.
VIETQR_DEMO_ENABLED=false
