###############################################################################
# DAO-EDU INFRASTRUCTURE ENVIRONMENT VARIABLES TEMPLATE
# Hướng dẫn: Sao chép file này thành .env trên server và thay đổi giá trị bảo mật
# Lệnh: cp .env.example .env
###############################################################################

# =============================================================================
# 1. DATABASE CONFIGURATION (POSTGRESQL)
# =============================================================================
# Tên Database sử dụng cho hệ thống
POSTGRES_DB=dao_edu_db

# Tài khoản quản trị Database (Nên đặt tên khác với admin/postgres để bảo mật)
POSTGRES_USER=dao_edu_admin

# MẬT KHẨU MẠNH CHO DATABASE (BẮT BUỘC THAY ĐỔI TRÊN PRODUCTION)
# Khuyến nghị: Sử dụng mật khẩu ngẫu nhiên tối thiểu 16 ký tự bao gồm chữ hoa, thường, số, ký tự đặc biệt
POSTGRES_PASSWORD=your_super_secure_random_db_password_here

# Cổng PostgreSQL chạy trên Host (Mặc định được thay đổi thành 5435 để tránh xung đột cổng 5432 mặc định đang chạy trên server)
# Lưu ý: Cổng này chỉ bind vào 127.0.0.1 để bảo mật.
POSTGRES_PORT=5435

# =============================================================================
# 2. STORAGE CONFIGURATION (MINIO)
# =============================================================================
# Tài khoản Root Admin của MinIO Console & API (Tối thiểu 3 ký tự)
MINIO_ROOT_USER=minio_admin

# MẬT KHẨU ROOT ADMIN CỦA MINIO (BẮT BUỘC THAY ĐỔI TRÊN PRODUCTION)
# Khuyến nghị: Sử dụng mật khẩu ngẫu nhiên tối thiểu 16 ký tự
MINIO_ROOT_PASSWORD=your_super_secure_random_minio_password_here

# Cổng truy cập API của MinIO (Đã đổi thành 9005 để tránh xung đột với cổng 9000 đang chạy trên server)
MINIO_API_PORT=9005

# Cổng truy cập Giao diện Web của MinIO Console (Đã đổi thành 9006 để tránh xung đột với cổng 9001 đang chạy trên server)
MINIO_CONSOLE_PORT=9006

# =============================================================================
# 3. DOCKER SYSTEM CONFIGURATION
# =============================================================================
# Tên project Docker Compose (Sử dụng làm tiền tố cho container/volume/network)
COMPOSE_PROJECT_NAME=dao-edu-production-infra

# Trạng thái khởi chạy lại container khi có lỗi hoặc server reboot (always, unless-stopped)
RESTART_POLICY=always
